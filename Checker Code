# ── Entry point ───────────────────────────────────────────────────────────────

def main():
divider = “=” * 56
print(f”\n{divider}”)
print(f”  DVSA Slot Checker  |  {datetime.utcnow().strftime(’%d %b %Y %H:%M UTC’)}”)
print(f”  Cheltenham  |  {DATE_FROM} → {DATE_TO}”)
print(f”{divider}\n”)

```
# Validate that all secrets are present
missing = [
    name for name, val in {
        "DVSA_LICENCE_NUMBER":   LICENCE_NUMBER,
        "DVSA_BOOKING_REFERENCE": BOOKING_REFERENCE,
        "EMAIL_SENDER":          EMAIL_SENDER,
        "EMAIL_APP_PASSWORD":    EMAIL_APP_PASS,
        "EMAIL_RECIPIENT":       EMAIL_TO,
        "NTFY_TOPIC":            NTFY_TOPIC,
    }.items()
    if not val
]
if missing:
    print(f"✗ Missing environment variables: {', '.join(missing)}")
    print("  Add these as GitHub Secrets — see README.md")
    sys.exit(1)

s = get_session()

if not login(s):
    sys.exit(1)

centre_id = find_cheltenham_centre(s)
if not centre_id:
    sys.exit(1)

print(f"\nChecking availability at centre {centre_id}…")
slots = get_available_slots(s, centre_id)

print(f"\n{divider}")
if slots:
    print(f"  🎉 {len(slots)} slot(s) found — sending notifications!")
    for d in slots:
        print(f"     {d.strftime('%A %-d %B %Y')}")
    print(f"{divider}\n")
    send_email(slots)
    send_ntfy(slots)
else:
    print("  No slots available in the target range.")
    print("  Will check again at the next scheduled run.")
    print(f"{divider}\n")
```

if **name** == “**main**”:
main()
