LICENCE_NUMBER    = os.environ.get(“DVSA_LICENCE_NUMBER”, “”)
BOOKING_REFERENCE = os.environ.get(“DVSA_BOOKING_REFERENCE”, “”)  # e.g. 71703094
EMAIL_SENDER      = os.environ.get(“EMAIL_SENDER”, “”)        # your Gmail address
