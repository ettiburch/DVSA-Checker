def send_ntfy(slots: list[date]) -> None:
“”“Send a push notification via ntfy.sh.”””
# Show up to 5 dates in the notification body
preview = “, “.join(d.strftime(”%-d %b”) for d in slots[:5])
if len(slots) > 5:
preview += f” +{len(slots) - 5} more”

```
payload = {
    "topic":    NTFY_TOPIC,
    "title":    f"🚗 DVSA: {len(slots)} Cheltenham slot(s) free!",
    "message":  f"{preview} — book now before they go!",
    "priority": "high",
    "tags":     ["car", "rotating_light"],
