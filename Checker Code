# ── Login ─────────────────────────────────────────────────────────────────────

def login(s: requests.Session) -> bool:
“””
Log in using an existing booking reference + driving licence number.
This is the simpler ‘manage your booking’ flow, available because
the user already has a test booked (September 2026, ref 71703094).

```
DVSA flow:
  1. Load the manage-booking login page (collects cookies + CSRF token)
  2. POST booking reference + licence number
  3. Confirm we land on the booking management page
"""
try:
    # Step 1 — load the manage-booking login page
    r = s.get(f"{BASE_URL}/manage-booking/login", timeout=20)
    r.raise_for_status()
    soup = BeautifulSoup(r.text, "html.parser")

    # Collect all hidden fields (CSRF tokens etc.)
    form = {
        tag["name"]: tag.get("value", "")
        for tag in soup.select("input[type='hidden']")
        if tag.get("name")
    }
    form["bookingReference"] = BOOKING_REFERENCE
    form["licenceNumber"]    = LICENCE_NUMBER

    # Step 2 — submit credentials
    r = s.post(f"{BASE_URL}/manage-booking/login", data=form, timeout=20)
    r.raise_for_status()

    # Success: DVSA redirects to the booking overview page
    if "manage-booking" in r.url and "login" not in r.url:
        print("✓ Logged in via booking reference")
        return True

    # Fallback: 200 on the same URL sometimes means success too
    if r.status_code == 200 and "bookingReference" not in r.text:
        print("✓ Logged in via booking reference (200 response)")
        return True

    print(f"✗ Login failed — still on login page or unexpected URL: {r.url}")
    print("  Check DVSA_BOOKING_REFERENCE and DVSA_LICENCE_NUMBER are correct.")
    return False

except requests.RequestException as e:
    print(f"✗ Login request error: {e}")
    return False
```

# ── Find Cheltenham test centre ───────────────────────────────────────────────

def find_cheltenham_centre(s: requests.Session) -> str | None:
“””
Search the DVSA system for Cheltenham test centre and return its centre ID.
The ID is extracted from the link href in the results page.
“””
try:
r = s.get(
f”{BASE_URL}/test-centre-results/nearest”,
params={“searchQuery”: “Cheltenham”, “distance”: “10”},
timeout=20,
)
r.raise_for_status()
soup = BeautifulSoup(r.text, “html.parser”)

```
    # DVSA result links look like /test-centre-results/{centre_id}/availability
    for link in soup.select("a[href*='test-centre']"):
        if "cheltenham" in link.text.lower() or "cheltenham" in link.get("href", "").lower():
            parts = [p for p in link["href"].split("/") if p]
            # href pattern: test-centre-results / {id} / availability
            if len(parts) >= 2:
                centre_id = parts[-2]
                print(f"✓ Found Cheltenham centre ID: {centre_id}")
                return centre_id

    # Fallback: try the first result if there's only one centre near Cheltenham
    first = soup.select_one("a[href*='test-centre-results']")
    if first:
        parts = [p for p in first["href"].split("/") if p]
        if len(parts) >= 2:
            centre_id = parts[-2]
            print(f"⚠ Using nearest centre (ID: {centre_id}) — verify this is Cheltenham")
            return centre_id

    print("✗ Could not find Cheltenham test centre in results")
    print("  HTML snippet for debugging:")
    print(soup.prettify()[:2000])
    return None

except requests.RequestException as e:
    print(f"✗ Centre search error: {e}")
    return None
```

# ── Check availability ────────────────────────────────────────────────────────

def get_available_slots(s: requests.Session, centre_id: str) -> list[date]:
“””
Iterate month-by-month through the target date range and return a list
of available test dates at the given centre.
“””
available: list[date] = []

```
# Build a list of month start dates to query
months_to_check = []
current = DATE_FROM.replace(day=1)
while current <= DATE_TO:
    months_to_check.append(current)
    if current.month == 12:
        current = current.replace(year=current.year + 1, month=1)
    else:
        current = current.replace(month=current.month + 1)

for month_start in months_to_check:
    print(f"  Checking {month_start.strftime('%B %Y')}…", end=" ")
    try:
        r = s.get(
            f"{BASE_URL}/test-centre-results/{centre_id}/availability",
            params={
                "preferredDate":  month_start.strftime("%Y-%m-%d"),
                "numberOfMonths": "1",
            },
            timeout=20,
        )
        r.raise_for_status()

        month_slots: list[date] = []

        # Attempt 1: JSON response (some DVSA endpoints return JSON)
        try:
            data = r.json()
            for slot in data.get("testSlots", []):
                raw = slot.get("date", "")
                try:
                    d = datetime.strptime(raw[:10], "%Y-%m-%d").date()
                    if DATE_FROM <= d <= DATE_TO:
                        month_slots.append(d)
                except ValueError:
                    pass
        except ValueError:
            pass  # not JSON — fall through to HTML parsing

        # Attempt 2: HTML calendar parsing
        if not month_slots:
            soup = BeautifulSoup(r.text, "html.parser")

            # DVSA calendar uses classes like 'BookingCalendar-date--bookable'
            # and data attributes like data-date or data-target-date
            selectors = [
                ".BookingCalendar-date--bookable",
                "[data-date]",
                "[data-target-date]",
                "td.available",
            ]
            for sel in selectors:
                for cell in soup.select(sel):
                    raw = (
                        cell.get("data-date")
                        or cell.get("data-target-date")
                        or cell.get("data-value")
                    )
                    if raw:
                        try:
                            d = datetime.strptime(raw[:10], "%Y-%m-%d").date()
                            if DATE_FROM <= d <= DATE_TO:
                                month_slots.append(d)
                        except ValueError:
                            pass

        if month_slots:
            print(f"✓ {len(month_slots)} slot(s) found")
            available.extend(month_slots)
        else:
            print("none available")

    except requests.RequestException as e:
        print(f"error — {e}")

return sorted(set(available))
```

